# ──────────────────────────────────────────────
# Terrarium .gitignore
# ──────────────────────────────────────────────

# Terrarium local config & runtime data
terrarium.local.toml
terrarium.development.toml.bak
data/
dev_data/
terrarium_data/
logs/
reports/
snapshots/

# Internal docs (specs, plans — not for public release)
internal_docs/

# Internal development tracking
IMPLEMENTATION_STATUS.md
MASTER_ISSUES.md
OPEN_QUESTIONS.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
ENV/
env/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
sdist/
wheels/

# Testing
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Linting
.ruff_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# Node (npx cache for @aisuite/chub)
node_modules/
package-lock.json

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Environment variables
.env
.env.*
!.env.example
